VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# REQUIRED: Developer token (NOT Editor — Editor API tokens are read-only on most projects)
# Create at: sanity.io/manage → your project → API → Tokens → Add API token → Developer
# Verify with: npm run test:sanity
VITE_SANITY_TOKEN=your_developer_token

# Optional: Google Sheets attendance log (Apps Script web app URL)
# See README → "Google Sheets Integration" for setup steps
# VITE_GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
